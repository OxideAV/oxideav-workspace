/target
**/*.rs.bk
Cargo.lock.bak
.DS_Store
*.swp
*.swo
# Claude Code session state (worktrees, plans, memory).
.claude/

# scripts/clone-crates.sh populates crates/ with per-crate checkouts
# of every OxideAV/oxideav{,-*} repo. Each of those is its own git repo
# (with its own .git dir, CI, and release-plz cadence) — the workspace
# repo must not track their contents or the trees would clash.
# Native workspace members stay tracked via the explicit `!` re-includes.
/crates/*
!/crates/oxideav-cli/
!/crates/oxideav-tests/
!/crates/oxideplay/

# Internal reference materials (OxideAV/docs). Private repo, cloned here
# on demand for contributor use — not tracked by the workspace.
/docs

# Test media fixtures dropped at the workspace root by the developer
# (e.g. for spot-checking decoder output via oxideplay). Not source.
*.mp4
*.mkv
*.webm
*.m4a
*.aac
*.wav
*.s16
